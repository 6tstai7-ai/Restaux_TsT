# ============================================
# Restaux API — Environment Variables
# ============================================
# Copy to apps/api/.env locally, or inject as secrets on Render.
# DO NOT commit real values.

# --- Runtime ---
NODE_ENV=production
API_PORT=3001

# --- Frontend (CORS allow-list) ---
FRONTEND_URL=https://your-app.vercel.app

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# --- Twilio (SMS, A2P 10DLC) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Apple Wallet (optional, sprint wallet) ---
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_ORGANIZATION_NAME=
APPLE_WALLET_CERT_PATH=
APPLE_WALLET_CERT_PASSWORD=
APPLE_WALLET_WWDR_CERT_PATH=

# --- Google Wallet (optional) ---
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY_PATH=

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
