# ============================================
# Restaurant SaaS — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.

# ============================================
# ENV
# ============================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# SUPABASE (sprint 1+)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-NEVER-EXPOSE

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ============================================
# ANTHROPIC / CLAUDE (sprint 3+)
# ============================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# TWILIO SMS (sprint 4+)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ============================================
# RESEND EMAIL (sprint 4+)
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# APPLE WALLET (sprint 2+)
# ============================================
APPLE_WALLET_PASS_TYPE_ID=pass.com.yourdomain.loyalty
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_ORGANIZATION_NAME=
APPLE_WALLET_CERT_PATH=./credentials/apple-wallet-cert.p12
APPLE_WALLET_CERT_PASSWORD=
APPLE_WALLET_WWDR_CERT_PATH=./credentials/apple-wwdr.pem

APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./credentials/apns-key.p8

# ============================================
# GOOGLE WALLET (sprint 2+)
# ============================================
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-wallet-service-account.json

# ============================================
# STRIPE (sprint 6+)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_SETUP=

# ============================================
# SENTRY (sprint 6+)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================
# APP CONFIG
# ============================================
API_PORT=3001
WEB_PORT=5173
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:5173

# ============================================
# MOCKS (dev uniquement)
# ============================================
USE_MOCK_TWILIO=false
USE_MOCK_RESEND=false
USE_MOCK_WALLET=false
USE_MOCK_CLAUDE=false